# NimHub Frontend Configuration (Next.js) — EXAMPLE
#
# Copy to .env.local and fill in.
#
# IMPORTANT: With BFF (Backend-for-Frontend) pattern, API secrets are
# now server-side only. No more NEXT_PUBLIC_API_SECRET!
#
# The frontend calls /api/* (Next.js API routes) which proxy to Railway.

# Nimiq Hub API URL (mainnet)
NEXT_PUBLIC_NIMIQ_HUB_URL=https://hub.nimiq.com

# Nimiq network
NEXT_PUBLIC_NIMIQ_NETWORK=mainnet

# Nimiq environment for staking (testnet or mainnet)
NEXT_PUBLIC_NIMIQ_ENV=mainnet

# Public service wallet address (receives payments — safe to expose)
NEXT_PUBLIC_SERVICE_ADDRESS=NQ07_YOUR_SERVICE_WALLET_ADDRESS_HERE

# Frontend URL (for QR codes and sharing)
NEXT_PUBLIC_FRONTEND_URL=https://your-app.vercel.app

# ============================================================================
# SERVER-SIDE ONLY (Not NEXT_PUBLIC_* - these stay on the server!)
# ============================================================================

# Backend API URL (Railway)
BACKEND_URL=

# API Secret Key (for server-to-server authentication)
API_SECRET=your_random_secret_key_here

# Nimiq environment for backend staking API (testnet or mainnet)
NIMIQ_ENV=mainnet



# Reloadly Integration (Gift Cards, Airtime, Bills)
# Get credentials from: https://www.reloadly.com/developers/api-settings
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
# Set to 'true' ONLY for local sandbox testing. Leave unset or 'false' for production.
RELOADLY_SANDBOX=false

# Email Service (Resend) - Get API key from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Hot Wallet (Automated NIM Sending) - KEEP RECOVERY PHRASE SECRET!
HOT_WALLET_ADDRESS=NQ07_YOUR_HOT_WALLET_ADDRESS_HERE
HOT_WALLET_RECOVERY_PHRASE=word1 word2 word3 ... word24
NIMIQ_RPC_URL=https://rpc.nimiqwatch.com

# Optional
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
