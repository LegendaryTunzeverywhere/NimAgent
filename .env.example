# NimHub Frontend Configuration (Next.js) — EXAMPLE
#
# Copy to .env.local and fill in. Only NEXT_PUBLIC_* variables belong here;
# they are inlined into the client bundle and are PUBLIC by definition.
# NEVER put secrets (API keys, service-role keys, client secrets) in this file.
# Backend secrets live in nimsplit/server/.env (see nimsplit/server/.env.example).

# Nimiq Hub API URL (testnet or mainnet)
NEXT_PUBLIC_NIMIQ_HUB_URL=https://hub.nimiq-testnet.com
# For mainnet, use: https://hub.nimiq.com

# Nimiq network
NEXT_PUBLIC_NIMIQ_NETWORK=testnet

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public service wallet address (receives payments — safe to expose)
NEXT_PUBLIC_SERVICE_ADDRESS=NQ07_YOUR_SERVICE_WALLET_ADDRESS_HERE

# Frontend URL (for QR codes and sharing)
NEXT_PUBLIC_FRONTEND_URL=https://your-app.vercel.app

# Optional
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
